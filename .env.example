# Ripple Transit — Environment template. Copy to .env and fill in.

NODE_ENV=development
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
SESSION_SECRET=change-me

# Local SQLite; for cloud use a Turso libsql:// URL + auth token.
DATABASE_URL=file:./data/ripple.db
DATABASE_AUTH_TOKEN=

# OneMap — pre-issued 3-day JWT. Set email/password to enable auto-refresh.
# Register at https://www.onemap.gov.sg/apidocs/register
ONEMAP_TOKEN=
ONEMAP_EMAIL=
ONEMAP_PASSWORD=

# LTA DataMall AccountKey — https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_ACCOUNT_KEY=

# HERE API key — https://platform.here.com
HERE_API_KEY=
HERE_MONTHLY_CAP=29950
