{
  "name": "ripple-transit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Real-time urban mobility intelligence for Singapore",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development PORT=5173 CLIENT_ORIGIN=http://localhost:5173 tsx watch server/index.ts",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "tsx server/index.ts",
    "start:prod": "npm run db:migrate && npm run db:seed && npm run start",
    "preview:serve": "cross-env NODE_ENV=production PORT=5173 CLIENT_ORIGIN=http://localhost:5173 tsx server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx drizzle/migrate.ts",
    "db:seed": "tsx drizzle/seed.ts",
    "db:reset": "rm -f data/ripple.db && npm run db:migrate && npm run db:seed",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@libsql/client": "^0.15.7",
    "@tanstack/react-query": "^5.66.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.0.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.2",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "sonner": "^1.7.2",
    "superjson": "^2.2.2",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.19.2",
    "wouter": "^3.5.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
